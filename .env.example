# ─── Database ─────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/farida-coffee

# ─── Session ──────────────────────────────────────────────────
SESSION_SECRET=farida-coffee-super-secret-change-this-in-production

# ─── Stripe Payments ──────────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_PUBLIC_KEY=pk_test_your_public_key_here
STRIPE_SECRET_KEY=sk_test_your_secret_key_here

# ─── Email (Nodemailer) ───────────────────────────────────────
# Use Gmail App Password: https://myaccount.google.com/apppasswords
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# ─── Server ───────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
