<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> — Farida Coffee</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>☕</text></svg>">
</head>
<body>

<!-- ─── Navbar ─────────────────────────────────────────────── -->
<nav class="navbar">
  <div class="navbar-inner">
    <a href="/" class="navbar-brand">Farida<span>.</span>Coffee</a>
    <ul class="navbar-nav">
      <li class="nav-item-hide"><a href="/products">Shop</a></li>
      <li class="nav-item-hide"><a href="/products?category=beans">Beans</a></li>
      <li class="nav-item-hide"><a href="/products?category=cold-brew">Cold Brew</a></li>
      <% if (isAdmin) { %>
  <li><a href="/admin" style="
    background: var(--espresso);
    color: var(--cream) !important;
    padding: 7px 16px;
    border-radius: 50px;
    font-size: 0.82rem;
  ">⚙️ Dashboard</a></li>
<% } %>
      <% if (!currentUser) { %>
        <li><a href="/auth/login">Login</a></li>
        
      <% } else { %>
        <li><a href="/auth/logout">Logout</a></li>
      <% } %>
      <li><a href="/orders">My Orders</a></li>
      <li>
        <a href="/cart" class="nav-cart">
          🛒 Cart
          <% if (cartCount > 0) { %>
            <span class="cart-badge"><%= cartCount %></span>
          <% } %>
        </a>
      </li>
    </ul>
  </div>
</nav>

<!-- ─── Flash Messages ─────────────────────────────────────── -->
<% if (success && success.length > 0) { %>
  <div class="container" style="padding-top:16px">
    <% success.forEach(msg => { %>
      <div class="flash flash-success">✓ <%= msg %></div>
    <% }) %>
  </div>
<% } %>
<% if (error && error.length > 0) { %>
  <div class="container" style="padding-top:16px">
    <% error.forEach(msg => { %>
      <div class="flash flash-error">✕ <%= msg %></div>
    <% }) %>
  </div>
<% } %>

<!-- ─── Main Content ───────────────────────────────────────── -->
<%- body %>

<!-- ─── Footer ────────────────────────────────────────────── -->
<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <div>
        <div class="footer-brand">Farida<span>.</span>Coffee</div>
        <p style="font-size:.9rem;max-width:280px;line-height:1.7">
          Specialty coffee sourced from the finest farms around the world.
          Roasted fresh and delivered to your door.
        </p>
      </div>
      <div>
        <h4>Shop</h4>
        <ul>
          <li><a href="/products?category=beans">Coffee Beans</a></li>
          <li><a href="/products?category=espresso">Espresso</a></li>
          <li><a href="/products?category=cold-brew">Cold Brew</a></li>
          <li><a href="/products?category=filter">Filter</a></li>
        </ul>
      </div>
      <div>
        <h4>Info</h4>
        <ul>
          <li><a href="#">About Us</a></li>
          <li><a href="#">Our Story</a></li>
          <li><a href="#">Shipping</a></li>
          <li><a href="#">Returns</a></li>
        </ul>
      </div>
      <div>
        <h4>Contact</h4>
        <ul>
          <li><a href="#">hello@farida.coffee</a></li>
          <li><a href="#">WhatsApp</a></li>
          <li><a href="#">Instagram</a></li>
          <li><a href="#">Facebook</a></li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <p>© <%= new Date().getFullYear() %> Farida Coffee. Made with ☕ in Cairo.</p>
    </div>
  </div>
</footer>

<script src="/js/main.js"></script>
</body>
</html>
