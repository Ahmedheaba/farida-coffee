<section style="min-height:80vh;display:flex;align-items:center;background:var(--cream)">
  <div class="container" style="max-width:480px">

    <div style="text-align:center;margin-bottom:36px">
      <div style="font-size:3rem;margin-bottom:16px">📦</div>
      <h1 style="font-family:var(--ff-display);font-size:1.8rem;margin-bottom:8px">
        Track Your Order
      </h1>
      <p style="color:var(--warm-gray)">
        Enter your email and order number to see your order status
      </p>
    </div>

    <% if (locals.error) { %>
      <div class="flash flash-error" style="margin-bottom:20px">✕ <%= error %></div>
    <% } %>

    <div class="checkout-card">
      <form action="/orders/track" method="POST">
        <div class="form-group">
          <label class="form-label">Email Address</label>
          <input type="email" name="email" class="form-control"
                 required placeholder="The email you used at checkout">
        </div>
        <div class="form-group">
          <label class="form-label">Order Number</label>
          <input type="text" name="orderNumber" class="form-control"
                 required placeholder="e.g. FC-12345678"
                 style="text-transform:uppercase">
        </div>
        <button type="submit" class="btn btn-primary btn-block">
          Track Order →
        </button>
      </form>

      <p style="text-align:center;margin-top:20px;font-size:.88rem;color:var(--warm-gray)">
        Have an account?
        <a href="/auth/login" style="color:var(--caramel);font-weight:700">Sign in</a>
        to see all your orders
      </p>
    </div>
  </div>
</section>