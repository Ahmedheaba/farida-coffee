<section class="section">
  <div class="container" style="max-width:680px">
    
    <a href="/orders" style="font-size:.85rem;color:var(--warm-gray)">← My Orders</a>

    <div style="text-align:center;margin:32px 0">
      <h1 style="font-family:var(--ff-display);font-size:1.8rem;margin-bottom:8px">
        Order <%= order.orderNumber %>
      </h1>
      <p style="color:var(--warm-gray)">
        Placed on <%= new Date(order.createdAt).toLocaleDateString('en-EG', { weekday:'long', year:'numeric', month:'long', day:'numeric' }) %>
      </p>
    </div>

    <!-- Progress Tracker -->
    <%
      const steps = ['pending', 'confirmed', 'processing', 'shipped', 'delivered'];
      const icons  = ['🕐', '✅', '☕', '🚚', '🎉'];
      const labels = ['Order Placed', 'Confirmed', 'Preparing', 'Shipped', 'Delivered'];
      const currentIndex = steps.indexOf(order.status);
    %>

    <div style="background:white;border-radius:16px;padding:40px;box-shadow:var(--shadow-sm);margin-bottom:24px">
      
      <!-- Step Indicators -->
      <div style="display:flex;justify-content:space-between;position:relative;margin-bottom:40px">
        
        <!-- Progress Line Background -->
        <div style="position:absolute;top:24px;left:10%;right:10%;height:3px;background:var(--cream-dark);z-index:0"></div>
        
        <!-- Progress Line Fill -->
        <div style="position:absolute;top:24px;left:10%;height:3px;background:var(--caramel);z-index:1;
                    width:<%= order.status === 'cancelled' ? '0' : (currentIndex / (steps.length - 1) * 80) %>%;
                    transition:width .5s ease"></div>

        <% steps.forEach((step, i) => {
          const done    = i <= currentIndex && order.status !== 'cancelled';
          const current = i === currentIndex && order.status !== 'cancelled';
        %>
          <div style="display:flex;flex-direction:column;align-items:center;gap:10px;z-index:2;flex:1">
            <div style="
              width:48px;height:48px;border-radius:50%;
              display:flex;align-items:center;justify-content:center;
              font-size:1.3rem;
              background:<%= done ? 'var(--caramel)' : 'var(--cream-dark)' %>;
              border:3px solid <%= current ? 'var(--espresso)' : done ? 'var(--caramel)' : 'var(--cream-dark)' %>;
              box-shadow:<%= current ? '0 0 0 4px rgba(196,126,58,.2)' : 'none' %>;
              transition:all .3s
            ">
              <%= icons[i] %>
            </div>
            <div style="font-size:.75rem;font-weight:700;text-align:center;color:<%= done ? 'var(--espresso)' : 'var(--warm-gray)' %>">
              <%= labels[i] %>
            </div>
          </div>
        <% }) %>
      </div>

      <!-- Cancelled State -->
      <% if (order.status === 'cancelled') { %>
        <div style="text-align:center;padding:20px;background:#FAEBEB;border-radius:10px;color:var(--danger)">
          <div style="font-size:2rem;margin-bottom:8px">❌</div>
          <div style="font-weight:700">This order was cancelled</div>
        </div>
      <% } else { %>
        <!-- Current Status Message -->
        <div style="text-align:center;padding:20px;background:var(--cream);border-radius:10px">
          <%
            const messages = [
              "We've received your order and will confirm it shortly.",
              "Your order is confirmed! We're getting it ready.",
              "Our team is carefully preparing your coffee order. ☕",
              "Your coffee is on its way! Expect delivery soon. 🚚",
              "Your order has been delivered. Enjoy your coffee! 🎉"
            ];
          %>
          <div style="font-size:1.5rem;margin-bottom:8px"><%= icons[currentIndex] %></div>
          <div style="font-weight:700;font-size:1rem;margin-bottom:6px;color:var(--espresso)">
            <%= labels[currentIndex] %>
          </div>
          <div style="font-size:.9rem;color:var(--warm-gray)"><%= messages[currentIndex] %></div>
        </div>
      <% } %>
    </div>

    <!-- Order Summary -->
    <div style="background:white;border-radius:16px;padding:24px;box-shadow:var(--shadow-sm);margin-bottom:24px">
      <h3 style="font-family:var(--ff-display);font-size:1.1rem;margin-bottom:16px">Order Summary</h3>
      <% order.items.forEach(item => { %>
        <div style="display:flex;gap:12px;align-items:center;padding:10px 0;border-bottom:1px solid var(--cream-dark)">
          <img src="<%= item.image %>" alt="" style="width:48px;height:48px;object-fit:cover;border-radius:8px"
               onerror="this.src='https://images.unsplash.com/photo-1559056199-641a0ac8b55e?w=60&h=60&fit=crop'">
          <div style="flex:1">
            <div style="font-weight:700;font-size:.9rem"><%= item.name %></div>
            <div style="font-size:.8rem;color:var(--warm-gray)">Qty: <%= item.quantity %></div>
          </div>
          <div style="font-weight:700;font-size:.9rem">EGP <%= (item.price * item.quantity).toFixed(0) %></div>
        </div>
      <% }) %>
      <div style="padding-top:16px">
        <div class="cart-summary-row"><span>Subtotal</span><span>EGP <%= order.subtotal.toFixed(0) %></span></div>
        <div class="cart-summary-row"><span>Shipping</span><span>EGP <%= order.shippingCost %></span></div>
        <div class="cart-summary-total"><span>Total</span><span>EGP <%= order.total.toFixed(0) %></span></div>
      </div>
    </div>

    <!-- Delivery Info -->
    <div style="background:white;border-radius:16px;padding:24px;box-shadow:var(--shadow-sm)">
      <h3 style="font-family:var(--ff-display);font-size:1.1rem;margin-bottom:16px">Delivery Address</h3>
      <p style="color:var(--warm-gray);line-height:1.8;margin:0">
        👤 <strong style="color:var(--espresso)"><%= order.customer.name %></strong><br>
        📍 <%= order.shippingAddress.street %>, <%= order.shippingAddress.city %><br>
        📞 <%= order.customer.phone || 'Not provided' %>
      </p>
    </div>

  </div>
</section>