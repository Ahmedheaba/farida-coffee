<section class="section">
  <div class="container" style="max-width:800px">
    <h1 class="section-title">My Orders</h1>
    <div class="section-line"></div>

    <% if (orders.length === 0) { %>
      <div style="text-align:center;padding:80px 0;color:var(--warm-gray)">
        <div style="font-size:4rem;margin-bottom:20px">📦</div>
        <h2 style="font-family:var(--ff-display);margin-bottom:12px">No orders yet</h2>
        <p>You haven't placed any orders yet.</p>
        <a href="/products" class="btn btn-primary" style="margin-top:24px">
          Start Shopping
        </a>
      </div>
    <% } else { %>
      <div style="display:flex;flex-direction:column;gap:16px">
        <% orders.forEach(order => { %>
          <div style="background:white;border-radius:12px;padding:24px;box-shadow:var(--shadow-sm)">
            
            <!-- Order Header -->
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;flex-wrap:wrap;gap:12px">
              <div>
                <div style="font-size:.8rem;color:var(--warm-gray);text-transform:uppercase;letter-spacing:.08em">Order</div>
                <div style="font-family:var(--ff-display);font-size:1.2rem;font-weight:700"><%= order.orderNumber %></div>
              </div>
              <div style="text-align:center">
                <div style="font-size:.8rem;color:var(--warm-gray);text-transform:uppercase;letter-spacing:.08em">Date</div>
                <div style="font-weight:700;font-size:.9rem"><%= new Date(order.createdAt).toLocaleDateString() %></div>
              </div>
              <div style="text-align:center">
                <div style="font-size:.8rem;color:var(--warm-gray);text-transform:uppercase;letter-spacing:.08em">Total</div>
                <div style="font-family:var(--ff-display);font-weight:700">EGP <%= order.total.toFixed(0) %></div>
              </div>
              <span class="badge badge-<%= order.status %>" style="font-size:.85rem;padding:6px 16px">
                <%= order.status.charAt(0).toUpperCase() + order.status.slice(1) %>
              </span>
              <a href="/orders/<%= order._id %>/tracking" class="btn btn-dark btn-sm">
                Track Order →
              </a>
            </div>

            <!-- Items Preview -->
            <div style="display:flex;gap:8px;flex-wrap:wrap">
              <% order.items.forEach(item => { %>
                <div style="display:flex;align-items:center;gap:8px;background:var(--cream);padding:8px 12px;border-radius:8px">
                  <img src="<%= item.image %>" alt="" style="width:32px;height:32px;object-fit:cover;border-radius:4px"
                       onerror="this.src='https://images.unsplash.com/photo-1559056199-641a0ac8b55e?w=40&h=40&fit=crop'">
                  <span style="font-size:.85rem;font-weight:700"><%= item.name %></span>
                  <span style="font-size:.8rem;color:var(--warm-gray)">× <%= item.quantity %></span>
                </div>
              <% }) %>
            </div>

          </div>
        <% }) %>
      </div>
    <% } %>
  </div>
</section>