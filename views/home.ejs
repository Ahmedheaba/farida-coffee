<!-- Hero -->
<section class="hero">
  <div class="container">
    <div class="hero-content">
      <span class="hero-tag">☕ Specialty Coffee — Cairo</span>
      <h1 class="display">Coffee that<br><em>moves</em> your soul.</h1>
      <p>Single-origin beans, expertly roasted. Delivered fresh to your door anywhere in Egypt.</p>
      <div class="hero-actions">
        <a href="/products" class="btn btn-primary">Shop Now</a>
        <a href="/products?category=beans" class="btn btn-outline">Explore Beans</a>
      </div>
    </div>
  </div>
</section>

<!-- Category Strip -->
<section style="background:white;padding:0;border-bottom:1px solid var(--cream-dark)">
  <div class="container">
    <div style="display:flex;gap:0;overflow-x:auto">
      <% ['espresso','filter','cold-brew','beans','equipment'].forEach(cat => { %>
        <a href="/products?category=<%= cat %>"
           style="flex:1;min-width:120px;text-align:center;padding:20px 16px;font-size:.8rem;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--warm-gray);border-right:1px solid var(--cream-dark);transition:all .2s"
           onmouseover="this.style.background='var(--cream)';this.style.color='var(--espresso)'"
           onmouseout="this.style.background='white';this.style.color='var(--warm-gray)'">
          <%= cat.replace('-',' ') %>
        </a>
      <% }) %>
    </div>
  </div>
</section>

<!-- Featured Products -->
<section class="section">
  <div class="container">
    <p class="subtitle">Our Selection</p>
    <h2 class="section-title">Featured Coffees</h2>
    <div class="section-line"></div>
    <div class="products-grid">
      <% featured.forEach(product => { %>
        <div class="product-card">
          <a href="/products/<%= product._id %>">
            <div class="product-card-img">
              <img src="<%= product.image %>" alt="<%= product.name %>" loading="lazy"
                   onerror="this.src='https://images.unsplash.com/photo-1559056199-641a0ac8b55e?w=400&h=300&fit=crop'">
            </div>
          </a>
          <div class="product-card-body">
            <div class="product-tag"><%= product.category %> · <%= product.origin || '' %></div>
            <h3><a href="/products/<%= product._id %>"><%= product.name %></a></h3>
            <p><%= product.description.substring(0, 90) %>...</p>
            <div class="stars">
              ★★★★<%= product.rating >= 4.5 ? '★' : '☆' %>
              <span class="stars-count">(<%= product.reviewCount %>)</span>
            </div>
          </div>
          <div class="product-card-footer">
            <div class="product-price">
              <% if (product.compareAtPrice && product.compareAtPrice > product.price) { %>
                <del style="color:var(--warm-gray);font-size:0.85em;margin-right:6px">EGP <%= product.compareAtPrice.toFixed(0) %></del>
                <span style="color:var(--danger)">EGP <%= product.price.toFixed(0) %></span>
              <% } else { %>
                EGP <%= product.price.toFixed(0) %>
              <% } %>
              <span class="currency">/ <%= product.weight || '250g' %></span>
            </div>
            <form action="/cart/add" method="POST">
              <input type="hidden" name="productId" value="<%= product._id %>">
              <input type="hidden" name="quantity" value="1">
              <button type="submit" class="btn btn-dark btn-sm">Add to Cart</button>
            </form>
          </div>
        </div>
      <% }) %>
    </div>
    <div style="text-align:center;margin-top:40px">
      <a href="/products" class="btn btn-primary">View All Coffees →</a>
    </div>
  </div>
</section>

<!-- Find Your Perfect Roast Interactive Banner -->
<section class="section reveal" style="background:#0a0a0a;color:#faf6f1;text-align:center;">
  <div class="container">
    <h2 style="font-family:var(--ff-display);font-size:2.8rem;margin-bottom:16px;color:#faf6f1;">Not sure where to start?</h2>
    <p style="font-size:1.1rem;color:rgba(250,246,241,0.8);max-width:600px;margin:0 auto 40px;">
      How do you brew your coffee at home? Choose your method below and we'll recommend the perfect beans for you.
    </p>

    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(250px,1fr));gap:24px;max-width:900px;margin:0 auto;">
      
      <!-- Espresso -->
      <a href="/products?category=espresso" style="background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);border-radius:16px;padding:40px 20px;text-decoration:none;transition:all 0.3s ease;display:block;" 
         onmouseover="this.style.background='rgba(255,255,255,0.08)';this.style.transform='translateY(-5px)';this.style.borderColor='var(--caramel)';"
         onmouseout="this.style.background='rgba(255,255,255,0.04)';this.style.transform='none';this.style.borderColor='rgba(255,255,255,0.08)';">
        <div style="font-size:3.5rem;margin-bottom:16px;">☕</div>
        <h3 style="color:#faf6f1;margin-bottom:8px;font-size:1.4rem;">Espresso Machine</h3>
        <p style="color:rgba(250,246,241,0.6);font-size:0.9rem;margin:0;">Darker roasts, rich crema, bold chocolate & nutty notes.</p>
        <div style="color:var(--caramel);font-weight:700;margin-top:20px;font-size:0.85rem;text-transform:uppercase;letter-spacing:0.1em;">Show Beans →</div>
      </a>

      <!-- Filter / Pour Over -->
      <a href="/products?category=filter" style="background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);border-radius:16px;padding:40px 20px;text-decoration:none;transition:all 0.3s ease;display:block;"
         onmouseover="this.style.background='rgba(255,255,255,0.08)';this.style.transform='translateY(-5px)';this.style.borderColor='var(--caramel)';"
         onmouseout="this.style.background='rgba(255,255,255,0.04)';this.style.transform='none';this.style.borderColor='rgba(255,255,255,0.08)';">
        <div style="font-size:3.5rem;margin-bottom:16px;">⚗️</div>
        <h3 style="color:#faf6f1;margin-bottom:8px;font-size:1.4rem;">Filter / Pour-Over</h3>
        <p style="color:rgba(250,246,241,0.6);font-size:0.9rem;margin:0;">Lighter roasts, bright acidity, fruity & floral profiles.</p>
        <div style="color:var(--caramel);font-weight:700;margin-top:20px;font-size:0.85rem;text-transform:uppercase;letter-spacing:0.1em;">Show Beans →</div>
      </a>

      <!-- Cold Brew -->
      <a href="/products?category=cold-brew" style="background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);border-radius:16px;padding:40px 20px;text-decoration:none;transition:all 0.3s ease;display:block;"
         onmouseover="this.style.background='rgba(255,255,255,0.08)';this.style.transform='translateY(-5px)';this.style.borderColor='var(--caramel)';"
         onmouseout="this.style.background='rgba(255,255,255,0.04)';this.style.transform='none';this.style.borderColor='rgba(255,255,255,0.08)';">
        <div style="font-size:3.5rem;margin-bottom:16px;">🧊</div>
        <h3 style="color:#faf6f1;margin-bottom:8px;font-size:1.4rem;">Cold Brew</h3>
        <p style="color:rgba(250,246,241,0.6);font-size:0.9rem;margin:0;">Smooth, low-acidity blends perfected for steep brewing.</p>
        <div style="color:var(--caramel);font-weight:700;margin-top:20px;font-size:0.85rem;text-transform:uppercase;letter-spacing:0.1em;">Show Beans →</div>
      </a>

    </div>
  </div>
</section>
